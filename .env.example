# ─────────────────────────────────────────────────────────────────────────────
# ThermoTrack — Variables d'environnement
# Copiez ce fichier en .env et renseignez vos valeurs Supabase
# ─────────────────────────────────────────────────────────────────────────────

# URL de votre projet Supabase
SUPABASE_URL="https://<project-id>.supabase.co"
VITE_SUPABASE_URL="https://<project-id>.supabase.co"

# Clé publique (anon/publishable) — visible côté client, sans secret
SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxxxxxxxxxxxxxxxxxxx"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxxxxxxxxxxxxxxxxxxx"

# ID du projet Supabase (affiché dans Project Settings)
VITE_SUPABASE_PROJECT_ID="<project-id>"
